  {{ figures.open_access_works | safe }}
  {% if openaccessworksinfo is defined and openaccessworksinfo %}<p class="dibiso-info">{{ openaccessworksinfo }}</p>{% endif %}
  <div class="dibiso-legend">
    <dl>
      <dt>TI dans HAL</dt><dd>PDF librement accessible pour tous sur l'archive ouverte HAL</dd>
      <dt>OA Hors HAL</dt><dd>PDF disponible sur les sites éditeurs, ou sur une archive ouverte autre que HAL, dépôt à l'étranger, disciplinaire tel qu'Arxiv, Pubmed, etc.</dd>
      <dt>Accès fermé</dt><dd>Notice seule sur HAL. En l'absence d'abonnement à la revue, les lecteurs n'ont pas accès au contenu.</dd>
    </dl>
  </div>
  {% if analyses.open_access_works is defined and analyses.open_access_works %}
  <div class="analysis">{{ analyses.open_access_works | safe }}</div>
  {% endif %}
</section>
