{% extends "base.html.j2" %}
{% set removed_sections = removed_sections | default([]) %}

{% block report_type_label %}Publications &amp; Partenariats{% endblock %}
{% block report_title %}Publications<br>&amp;<br>Partenariats{% endblock %}

{% block title_date %}{{ reportyear | default('') }}{% endblock %}

{% block title_subtitle %}<strong>{{ entitiesacronym | default('') }}</strong>{% if entitiesfullname is defined and entitiesfullname %}<br>{{ entitiesfullname }}{% endif %}{% endblock %}
{% block toc_entries %}
  {% if figures.topics_collaborations is defined and 'topics_collaborations' not in removed_sections %}<li><a href="#topics-collaborations">Principales thématiques de recherche</a></li>{% endif %}
  {% if figures.topics_potential_collaborations is defined and 'topics_potential_collaborations' not in removed_sections %}<li><a href="#topics-potential">Potentiel de collaboration identifié</a></li>{% endif %}
  {% if figures.institutions_lineage_collaborations is defined and 'institutions_lineage_collaborations' not in removed_sections %}<li><a href="#institutions">Top 25 structures internes</a></li>{% endif %}
  {% if figures.works_collaborations_normalized is defined and 'works_collaborations_normalized' not in removed_sections %}<li><a href="#works-citations-normalized">Top 25 co-publications (citations normalisées)</a></li>{% endif %}
  {% if figures.works_collaborations_count is defined and 'works_collaborations_count' not in removed_sections %}<li><a href="#works-citations-count">Top 25 co-publications (citations)</a></li>{% endif %}
  {% if 'analysis' not in removed_sections %}<li><a href="#analysis">Analyse</a></li>{% endif %}
{% endblock %}

{% block main_content %}

{% if figures.topics_collaborations is defined and 'topics_collaborations' not in removed_sections %}
<section id="topics-collaborations" data-section="topics_collaborations">
  <h2>Principales thématiques de recherche</h2>
  {{ figures.topics_collaborations | safe }}
  {% if analyses.topics_collaborations is defined and analyses.topics_collaborations %}
  <div class="analysis">{{ analyses.topics_collaborations | safe }}</div>
  {% endif %}
</section>
{% endif %}

{% if figures.topics_potential_collaborations is defined and 'topics_potential_collaborations' not in removed_sections %}
<section id="topics-potential" data-section="topics_potential_collaborations">
  <h2>Potentiel de collaboration identifié</h2>
  {{ figures.topics_potential_collaborations | safe }}
  {% if analyses.topics_potential_collaborations is defined and analyses.topics_potential_collaborations %}
  <div class="analysis">{{ analyses.topics_potential_collaborations | safe }}</div>
  {% endif %}
</section>
{% endif %}

{% if figures.institutions_lineage_collaborations is defined and 'institutions_lineage_collaborations' not in removed_sections %}
<section id="institutions" data-section="institutions_lineage_collaborations">
  <h2>Top 25 structures internes</h2>
  {{ figures.institutions_lineage_collaborations | safe }}
  {% if analyses.institutions_lineage_collaborations is defined and analyses.institutions_lineage_collaborations %}
  <div class="analysis">{{ analyses.institutions_lineage_collaborations | safe }}</div>
  {% endif %}
</section>
{% endif %}

{% if figures.works_collaborations_normalized is defined and 'works_collaborations_normalized' not in removed_sections %}
<section id="works-citations-normalized" data-section="works_collaborations_normalized">
  <h2>Top 25 co-publications par citations normalisées</h2>
  {{ figures.works_collaborations_normalized | safe }}
  {% if analyses.works_collaborations_normalized is defined and analyses.works_collaborations_normalized %}
  <div class="analysis">{{ analyses.works_collaborations_normalized | safe }}</div>
  {% endif %}
</section>
{% endif %}

{% if figures.works_collaborations_count is defined and 'works_collaborations_count' not in removed_sections %}
<section id="works-citations-count" data-section="works_collaborations_count">
  <h2>Top 25 co-publications par citations</h2>
  {{ figures.works_collaborations_count | safe }}
  {% if analyses.works_collaborations_count is defined and analyses.works_collaborations_count %}
  <div class="analysis">{{ analyses.works_collaborations_count | safe }}</div>
  {% endif %}
</section>
{% endif %}

{% if 'analysis' not in removed_sections %}
<section id="analysis" data-section="analysis">
  <h2>Analyse</h2>
  {% if analyses.analysis is defined and analyses.analysis %}
  <div class="analysis">{{ analyses.analysis | safe }}</div>
  {% else %}
  <p class="dibiso-info"><em>Section à compléter.</em></p>
  {% endif %}
</section>
{% endif %}

{% endblock %}
